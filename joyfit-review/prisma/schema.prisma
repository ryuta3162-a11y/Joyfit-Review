generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

enum ReviewSource {
  GOOGLE
  MANUAL
}

enum ReviewReplyStatus {
  NONE
  DRAFTED
  POSTED
}

model Store {
  id                   String   @id @default(cuid())
  name                 String
  slug                 String   @unique
  googlePlaceId        String?  @unique
  googleReviewUrl      String?
  aiSystemPrompt       String   @default("親しみやすいトーンで。JOYFITのスタッフとして、丁寧で誠実に返信すること。")
  averageRating        Float    @default(0)
  totalReviewCount     Int      @default(0)
  lastReviewSyncedAt   DateTime?
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt

  reviews              Review[]
  internalFeedbacks    InternalFeedback[]
}

model Review {
  id                    String            @id @default(cuid())
  storeId               String
  externalReviewId      String?           @unique
  source                ReviewSource      @default(GOOGLE)
  reviewerName          String
  rating                Int
  comment               String
  reviewedAt            DateTime
  aiReplyDraft          String?
  staffReply            String?
  replyStatus           ReviewReplyStatus @default(NONE)
  repliedAt             DateTime?
  createdAt             DateTime          @default(now())
  updatedAt             DateTime          @updatedAt

  store                 Store             @relation(fields: [storeId], references: [id], onDelete: Cascade)

  @@index([storeId, reviewedAt(sort: Desc)])
  @@index([storeId, replyStatus])
}

model InternalFeedback {
  id         String   @id @default(cuid())
  storeId    String
  rating     Int
  message    String
  createdAt  DateTime @default(now())

  store      Store    @relation(fields: [storeId], references: [id], onDelete: Cascade)

  @@index([storeId, createdAt(sort: Desc)])
}
